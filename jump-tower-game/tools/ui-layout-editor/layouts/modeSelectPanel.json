        "consume": true
      }
    },
    {
      "id": "modeBadge",
      "type": "badge",
      "anchor": { "x": "center", "y": "center" },
      "offset": { "x": -110, "y": -244 },
      "size": { "width": 120, "height": 30 },
      "style": { "text": "MODE SELECT", "dotColor": "#7cf3c8", "color": "#f5fbff" }
