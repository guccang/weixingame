    {
      "id": "modeBg",
      "type": "glassPanel",
      "anchor": { "x": "center", "y": "center" },
      "offset": { "x": 0, "y": 0 },
      "size": { "width": 351, "height": 540 },
      "style": {
        "radius": 30,
        "innerStroke": "rgba(255,255,255,0.06)",
        "shadowBlur": 22,
        "glow": "rgba(122,201,255,0.12)",
        "stroke": "rgba(207,230,255,0.18)",
