{
  "id": "startScreen",
  "desc": "主页 - 首屏（无面板打开时）",
  "vars": {},
  "elements": [
    {
      "id": "overlay",
      "type": "rect",
      "anchor": { "x": "left", "y": "top" },
      "offset": { "x": 0, "y": 0 },
      "size": { "width": "100%", "height": "100%" },
      "style": { "fill": "rgba(2,8,16,0.18)" }
    },
    {
      "id": "statusBadge",
      "type": "badge",
      "anchor": { "x": "left", "y": "top" },
      "offset": { "x": 16, "y": 28 },
      "size": { "width": 120, "height": 30 },
      "style": {
        "text": "热身完成",
        "color": "$badgeText",
        "dotColor": "$heroAccent",
        "glow": "$panelGlow",
        "stroke": "$panelStroke"
      }
    },
    {
      "id": "title",
      "type": "text",
      "anchor": { "x": "center", "y": "top" },
      "offset": { "x": 0, "y": 68 },
      "size": { "width": 300, "height": 40 },
      "style": {
        "fontSize": 34,
        "fontWeight": "700",
        "textAlign": "center",
        "color": "$titleColor",
        "text": "跳跃塔"
      },
      "textKey": "GAME_TITLE"
    },
    {
      "id": "subtitle",
      "type": "text",
      "anchor": { "x": "center", "y": "top" },
      "offset": { "x": 0, "y": 100 },
      "size": { "width": 300, "height": 24 },
      "style": {
        "fontSize": 16,
        "fontWeight": "600",
        "textAlign": "center",
        "color": "$subtitleColor",
        "text": "无限攀登"
      },
      "textKey": "SUBTITLE"
    },
    {
      "id": "coinBadge",
      "type": "glassPanel",
      "anchor": { "x": "left", "y": "top" },
      "offset": { "x": 24, "y": 72 },
      "size": { "width": 126, "height": 40 },
      "style": {
        "radius": 20,
        "shadowBlur": 8,
        "glow": "$panelGlow",
        "stroke": "$panelStroke",
        "stops": "$panelMutedStops"
      },
      "action": { "type": "grant-debug-coins" },
      "children": [
        {
          "id": "coinLabel",
          "type": "text",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 64, "y": 77 },
          "size": { "width": 80, "height": 14 },
          "style": { "fontSize": 10, "fontWeight": "600", "color": "$chipLabel", "text": "能量币" }
        },
        {
          "id": "coinValue",
          "type": "text",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 64, "y": 90 },
          "size": { "width": 80, "height": 20 },
          "style": { "fontSize": 18, "fontWeight": "700", "color": "$cardLabel", "text": "0" }
        }
      ]
    },
    {
      "id": "heroPanel",
      "type": "glassPanel",
      "anchor": { "x": "center", "y": "top" },
      "offset": { "x": 0, "y": 186 },
      "size": { "width": 343, "height": 276 },
      "style": {
        "radius": 30,
        "glow": "$panelGlow",
        "shadowBlur": 14,
        "stroke": "$panelStroke",
        "innerStroke": "$panelInnerStroke",
        "stops": "$panelStrongStops"
      },
      "children": [
        {
          "id": "heroInnerCard",
          "type": "roundRect",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 34, "y": 206 },
          "size": { "width": 307, "height": 236 },
          "style": { "radius": 24, "fill": "$cardFill" }
        },
        {
          "id": "charStage",
          "type": "roundRect",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 38, "y": 212 },
          "size": { "width": 120, "height": 138 },
          "style": { "radius": 24, "fill": "rgba(255,255,255,0.08)" }
        },
        {
          "id": "charRoleLabel",
          "type": "text",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 176, "y": 218 },
          "size": { "width": 140, "height": 14 },
          "style": { "fontSize": 12, "fontWeight": "700", "color": "$heroAccent", "text": "当前主角" }
        },
        {
          "id": "charName",
          "type": "text",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 176, "y": 238 },
          "size": { "width": 140, "height": 28 },
          "style": { "fontSize": 24, "fontWeight": "700", "color": "$cardLabel", "text": "角色名" }
        },
        {
          "id": "metricStatus",
          "type": "roundRect",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 176, "y": 310 },
          "size": { "width": 150, "height": 32 },
          "style": { "radius": 14, "fill": "$cardFill" }
        },
        {
          "id": "metricDossier",
          "type": "roundRect",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 176, "y": 350 },
          "size": { "width": 150, "height": 32 },
          "style": { "radius": 14, "fill": "$cardFill" }
        },
        {
          "id": "metricCollection",
          "type": "roundRect",
          "anchor": { "x": "left", "y": "top" },
          "offset": { "x": 176, "y": 390 },
          "size": { "width": 150, "height": 32 },
          "style": { "radius": 14, "fill": "$cardFill" }
        }
      ]
    },
    {
      "id": "hint",
      "type": "text",
      "anchor": { "x": "center", "y": "top" },
      "offset": { "x": 0, "y": 478 },
      "size": { "width": 300, "height": 20 },
      "style": {
        "fontSize": 13,
        "textAlign": "center",
        "color": "$cardSubtle",
        "text": "点击开始游戏"
      },
      "textKey": "HINT"
    },
    {
      "id": "startBtn",
      "type": "actionButton",
      "anchor": { "x": "center", "y": "top" },
      "offset": { "x": 0, "y": 500 },
      "size": { "width": 220, "height": 56 },
      "style": {
        "radius": 28,
        "fontSize": 20,
        "fontWeight": "700",
        "textColor": "$buttonText",
        "shadowColor": "$buttonShadow",
        "stops": "$buttonPrimaryStops",
        "text": "开始游戏"
      },
      "textKey": "START_BUTTON",
      "action": { "type": "start-game", "mode": "endless" }
    },
    {
      "id": "settingsBtn",
      "type": "actionButton",
      "anchor": { "x": "right", "y": "top" },
      "offset": { "x": -126, "y": 28 },
      "size": { "width": 94, "height": 34 },
      "style": {
        "fontSize": 14,
        "fontWeight": "700",
        "textColor": "$buttonText",
        "shadowColor": "$buttonShadow",
        "stops": "$buttonPrimaryStops",
        "text": "Setting"
      },
      "action": { "type": "open-panel", "panel": "showSettingsPanel" }
    },
    {
      "id": "debugBtn",
      "type": "actionButton",
      "anchor": { "x": "right", "y": "top" },
      "offset": { "x": -22, "y": 28 },
      "size": { "width": 94, "height": 34 },
      "style": {
        "fontSize": 14,
        "fontWeight": "700",
        "textColor": "#271d16",
        "shadowColor": "rgba(219,175,138,0.18)",
        "stops": [[0, "#efdbc7"], [0.55, "#ddbc99"], [1, "#c79b7f"]],
        "text": "Debug"
      },
      "action": { "type": "open-debug-panel" }
    },
    {
      "id": "bottomNavBg",
      "type": "glassPanel",
      "anchor": { "x": "center", "y": "bottom" },
      "offset": { "x": 0, "y": -100 },
      "size": { "width": 351, "height": 102 },
      "style": {
        "radius": 26,
        "glow": "$panelGlow",
        "shadowBlur": 8,
        "stroke": "$panelStroke",
        "stops": "$navPanelStops"
      }
    },
    {
      "id": "bottomBar",
      "type": "flex",
      "anchor": { "x": "center", "y": "bottom" },
      "offset": { "x": 0, "y": -102 },
      "size": { "width": 340, "height": 78 },
      "flex": {
        "direction": "row",
        "gap": 6,
        "justify": "center",
        "align": "center"
      },
      "children": [
        {
          "id": "nav.shop",
          "type": "iconTile",
          "size": { "width": 52, "height": 78 },
          "style": { "label": "工坊", "labelSize": 10 },
          "textKey": "NAV_SHOP",
          "imageKey": "iconShop",
          "action": { "type": "open-panel", "panel": "showShopPanel" }
        },
        {
          "id": "nav.character",
          "type": "iconTile",
          "size": { "width": 52, "height": 78 },
          "style": { "label": "角色", "labelSize": 10 },
          "textKey": "NAV_CHARACTER",
          "imageKey": "iconCharacter",
          "action": { "type": "open-panel", "panel": "showCharacterPanel" }
        },
        {
          "id": "nav.mode",
          "type": "iconTile",
          "size": { "width": 52, "height": 78 },
          "style": { "label": "模式", "labelSize": 10 },
          "textKey": "NAV_MODE",
          "imageKey": "iconMode",
          "action": { "type": "open-panel", "panel": "showModeSelect" }
        },
        {
          "id": "nav.achievement",
          "type": "iconTile",
          "size": { "width": 52, "height": 78 },
          "style": { "label": "成就", "labelSize": 10 },
          "textKey": "NAV_ACHIEVEMENT",
          "imageKey": "iconAchievement",
          "action": { "type": "open-panel", "panel": "showAchievementPanel" }
        },
        {
          "id": "nav.leaderboard",
          "type": "iconTile",
          "size": { "width": 52, "height": 78 },
          "style": { "label": "排行", "labelSize": 10 },
          "textKey": "NAV_LEADERBOARD",
          "imageKey": "iconLeaderboard",
          "action": { "type": "open-panel", "panel": "showLeaderboardPanel" }
        },
        {
          "id": "nav.pet",
          "type": "iconTile",
          "size": { "width": 52, "height": 78 },
          "style": { "label": "宠物", "labelSize": 10 },
          "textKey": "NAV_PET",
          "imageKey": "iconPet",
          "action": { "type": "open-panel", "panel": "showPetPanel" }
        }
      ]
    }
  ]
}
